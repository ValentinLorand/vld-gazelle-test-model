{
  "id": "VLD_Demo_Capability_TestExecution",
  "name": "VLD Demo Capability TestExecution",
  "summary": "Test Case to demonstrate the mCSD test case possibilities",
  "description": "This test case is there to demonstrate the capability to execute different test steps (ITB, Simulation and Validation) in one automated test case",
  "tags": [
    "ITB",
    "VALIDATION",
    "SIMULATION"
  ],
  "testRoles": [
    {
      "name": "mCSD Server",
      "capabilities": {
        "or": [
          {
            "capability": "mCSD"
          }
        ]
      }
    }
  ],
  "supportedInputs": [
    {
      "id": "mCSD Request file",
      "type": "FILE",
      "label": "mCSD Request",
      "required": true
    },
    {
      "id": "fqdn_mCSD_Server",
      "type": "TEXT",
      "label": "mCSD Directory base URL",
      "required": true,
      "defaultValue": "https://ehealthsuisse.ihe-europe.net/mcsd-simulator/fhir/ch"
    },
    {
      "id": "fhir_base_url",
      "type": "TEXT",
      "label": "FHIR Base URL",
      "required": true
    }
  ],
  "steps": [
    {
      "name": "Checking mCSD request",
      "type": "VALIDATION",
      "properties": [
        {
          "name": "validationService",
          "type": "STRING",
          "value": "Matchbox"
        },
        {
          "name": "validationProfile",
          "type": "STRING",
          "value": "http://fhir.ch/ig/ch-epr-fhir/StructureDefinition/CH.mCSD.Practitioner"
        },
        {
          "name": "contentToValidate",
          "type": "BYTE_ARRAY",
          "value": "${mCSD Request file}"
        }
      ]
    },
    {
      "name": "Test_EPR mCSD ITI-130 Directory - Add Update and Delete a Practitioner",
      "type": "SIMULATION",
      "properties": [
        {
          "name": "simulationService",
          "value": "mCSD Simulator",
          "type": "STRING"
        },
        {
          "name": "sequenceId",
          "value": "EPR mCSD ITI-130 Directory - Add Update and Delete a Practitioner",
          "type": "STRING"
        },
        {
          "name": "Directory base URL",
          "value": "${fqdn_mCSD_Server}",
          "type": "STRING"
        }
      ]
    },
    {
      "name": "Executing test case SingleDocument on ITB",
      "type": "ITB",
      "properties": [
        {
          "name": "testCase",
          "type": "STRING",
          "value": "SingleDocument"
        },
        {
          "name": "systemID",
          "type": "STRING",
          "value": "488F410BX0A71X44C3X82F7XBB0B969FD3E3"
        },
        {
          "name": "actorID",
          "type": "STRING",
          "value": "753D8A15X5139X447FX9189X061FBF257204"
        },
        {
          "name": "executionMode",
          "type": "STRING",
          "value": "ASYNC"
        },
        {
          "name": "endpointAddress",
          "type": "STRING",
          "value": "${fhir_base_url}"
        }
      ]
    }
  ]
}