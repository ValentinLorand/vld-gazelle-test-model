{
    "id": "xcpd-iti55",
    "name": "XCPD Cross-Community Patient Discovery with ATNA and XUA",
    "summary": "Check the consistency of the ITI-55 transaction, including SAML assertion and produced audit messages.",
    "description": "After you have executed a ITI-55 transaction, both partners provide the required inputs and the test tools will check their conformance and verify that the exchange is consistent.",
    "tags": [
        "interoperability test",
        "peer-to-peer",
        "ITI-55",
        "XCPD",
        "ATNA",
        "XUA"        
    ],
    "testRoles": [
        {
            "name": "Initiating Gateway",
            "capabilities": {
                "and": [
                    {
                        "capability": "XCPD/Initiating Gateway"
                    },
                    {
                        "capability": "XUA/X-Service User"
                    },
                    {
                        "or": [
                            {
                                "capability": "ATNA/Secure Application"
                            },
                            {
                                "capability": "ATNA/Secure Node"
                            }
                        ]
                    }
                ]
            }
        },
        {
            "name": "Responding Gateway",
            "capabilities": {
                "and": [
                    {
                        "capability": "XCPD/Responding Gateway"
                    },
                    {
                        "capability": "XUA/X-Service Provider"
                    },
                    {
                        "or": [
                            {
                                "capability": "ATNA/Secure Application"
                            },
                            {
                                "capability": "ATNA/Secure Node"
                            }
                        ]
                    }
                ]
            }
        }
    ],
    "supportedInputs": [
        {
            "id": "saml_assertion",
            "label": "SAML Assertion",
            "type": "FILE",
            "required": true
        },
        {
            "id": "xcpd_request",
            "label": "XCPD request",
            "type": "FILE",
            "required": true
        },
        {
            "id": "xcpd_response",
            "label": "XCPD response",
            "type": "FILE",
            "required": true
        },
        {
            "id": "iti55_audit_initgw",
            "label": "ITI-55 Audit message [Initiating Gateway]",
            "type": "FILE",
            "required": true
        },
        {
            "id": "iti55_audit_respgw",
            "label": "ITI-55 Audit message [Responding Gateway]",
            "type": "FILE",
            "required": true
        }
    ],
    "steps": [
        {
            "name": "Check conformance of SAML Assertion",
            "type": "VALIDATION",
            "properties": [
                {
                    "name": "validationService",
                    "type": "STRING",
                    "value": "Assertions - Validator"
                },
                {
                    "name": "validationProfile",
                    "type": "STRING",
                    "value": "IHE - ITI - XUA"
                },
                {
                    "name": "contentToValidate",
                    "type": "BYTE_ARRAY",
                    "value": "${saml_assertion}"
                }
            ]
        },
        {
            "id": "Check conformance of ITI-55 request",
            "type": "VALIDATION",
            "properties": [
                {
                    "name": "validationService",
                    "type": "STRING",
                    "value": "Gazelle HL7v3 Validator"
                },
                {
                    "name": "validationProfile",
                    "type": "STRING",
                    "value": "[ITI-55] Cross Gateway Patient Discovery Request"
                },
                {
                    "name": "contentToValidate",
                    "type": "BYTE_ARRAY",
                    "value": "${xcpd_request}"
                }
            ]
        },
        {
            "id": "Check conformance of ITI-55 response",
            "type": "VALIDATION",
            "properties": [
                {
                    "name": "validationService",
                    "type": "STRING",
                    "value": "Gazelle HL7v3 Validator"
                },
                {
                    "name": "validationProfile",
                    "type": "STRING",
                    "value": "[ITI-55] Cross Gateway Patient Discovery Response"
                },
                {
                    "name": "contentToValidate",
                    "type": "BYTE_ARRAY",
                    "value": "${xcpd_response}"
                }
            ]
        },
        {
            "id": "Check conformance of ITI-55 Audit Message [Initiating Gateway]",
            "type": "VALIDATION",
            "properties": [
                {
                    "name": "validationService",
                    "type": "STRING",
                    "value": "AuditMessage - Validator"
                },
                {
                    "name": "validationProfile",
                    "type": "STRING",
                    "value": "IHE - ITI-55 XCPD Initiating Gateway audit message [DICOM extension compatible]"
                },
                {
                    "name": "contentToValidate",
                    "type": "BYTE_ARRAY",
                    "value": "${iti55_audit_initgw}"
                }
            ]
        },
        {
            "id": "Check conformance of ITI-55 Audit Message [Responding Gateway]",
            "type": "VALIDATION",
            "properties": [
                {
                    "name": "validationService",
                    "type": "STRING",
                    "value": "AuditMessage - Validator"
                },
                {
                    "name": "validationProfile",
                    "type": "STRING",
                    "value": "IHE - ITI-55 XCPD Responding Gateway audit message [DICOM extension compatible]"
                },
                {
                    "name": "contentToValidate",
                    "type": "BYTE_ARRAY",
                    "value": "${iti55_audit_respgw}"
                }
            ]
        },
        {
            "id": "Cross-verifications of the Identification service transaction",
            "type": "VALIDATION",
            "properties": [
                {
                    "name": "validationService",
                    "type": "STRING",
                    "value": "Cross Validation Service"
                },
                {
                    "name": "validationProfile",
                    "type": "STRING",
                    "value": "1.3.6.1.4.1.12559.11.30.1.1"
                },
                {
                    "name": "iti55-request",
                    "type": "BYTE_ARRAY",
                    "value": "${xcpd_request}"
                },
                {
                    "name": "iti55-response",
                    "type": "BYTE_ARRAY",
                    "value": "${xcpd_response}"
                },
                {
                    "name": "hcp_identity_assertion",
                    "type": "BYTE_ARRAY",
                    "value": "${saml_assertion}"
                },
                {
                    "name": "iti55_audit_ncpB",
                    "type": "BYTE_ARRAY",
                    "value": "${iti55_audit_initgw}"
                },
                {
                    "name": "iti55_audit_ncpA",
                    "type": "BYTE_ARRAY",
                    "value": "${iti55_audit_respgw}"
                }
            ]
        }
    ]
}